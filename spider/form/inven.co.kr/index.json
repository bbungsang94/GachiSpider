{
    "\\/board\\/webzine\\/2097\\/(\\d+)":
    {
        "title":{
            "method": "select",
            "tag": "#tbArticle div.articleTitle h1",
            "attrs": null
        },
        "images":{
            "method": "select",
            "tag": "#powerbbsContent img"
        },
        "videos":{
            "method": "select",
            "tag": "#powerbbsContent video"
        },
        "contents": 
        {
            "method": "select",
            "tag": "#powerbbsContent div",
            "attrs": null
        },
        "hits": 
        {
            "method": "select",
            "tag": "#tbArticle div.articleHit",
            "attrs": ["class", ["articleHit"]]
        }
    }
}